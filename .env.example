# ============================================================================
# ai-writer environment configuration
# ============================================================================
# Copy this file to `.env` and fill in the values you actually have.
# Anything left blank uses the defaults shown in the comment.

# ----------------------------------------------------------------------------
# Django core
# ----------------------------------------------------------------------------
# Use a long random string in production. Local dev can leave this blank.
DJANGO_SECRET_KEY=

# True for local dev, False in production.
DEBUG=True

# Verbosity for the stories / stories_v2 loggers.
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# ----------------------------------------------------------------------------
# MongoDB (shared by v1 + v2 — same cluster, separate collections)
# ----------------------------------------------------------------------------
# Use mongodb+srv://...mongodb.net/... for Atlas. The router auto-detects
# Atlas from the URI and enables $vectorSearch where available.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ai_writer

# Force the Atlas $vectorSearch path on even when the URI doesn't look like
# Atlas (e.g. local tunnel into Atlas). Leave blank to auto-detect.
MONGODB_ATLAS_VECTOR=


# ============================================================================
# stories_v2 AI providers — Groq + Together AI only
# ============================================================================
# Both are required. Groq powers the critic panel, context builders, and
# fallback writer; Together powers the Scene Writer + Editor (Kimi-K2.5)
# and the structured-JSON workhorses (gpt-oss-120b) plus embeddings.

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Get a key at https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1


# ----------------------------------------------------------------------------
# Optional: external AI-detector gate (Phase 7 humaniser)
# ----------------------------------------------------------------------------
# Leave blank to skip the external detector check. With this set, the
# humanisation pipeline can score final prose against GPTZero / Originality
# and trigger a surgical re-edit if score > 0.30.
STORIES_V2_AI_DETECTOR_KEY=


# ============================================================================
# stories v1 (legacy) — still needed because /api/stories/... uses Together AI
# ============================================================================
# The v1 stack uses Together AI directly via LangChain. Same key as
# TOGETHER_API_KEY above — declared here for v1 settings that read it
# under a different module path. You don't need separate Together accounts.

# Per-role model overrides for v1. Defaults shown are sensible.
TOGETHER_DEFAULT_MODEL=MiniMaxAI/MiniMax-M2.7
TOGETHER_MODEL=MiniMaxAI/MiniMax-M2.7
TOGETHER_PROFILE_MODEL=MiniMaxAI/MiniMax-M2.7
TOGETHER_PLANNER_MODEL=moonshotai/Kimi-K2.5
TOGETHER_WRITER_MODEL=moonshotai/Kimi-K2.5
TOGETHER_REVIEWER_MODEL=openai/gpt-oss-120b
TOGETHER_CONTINUITY_MODEL=openai/gpt-oss-120b
TOGETHER_SUMMARY_MODEL=openai/gpt-oss-120b
TOGETHER_PUBLISHER_MODEL=openai/gpt-oss-120b
TOGETHER_PERFECTIONIST_MODEL=moonshotai/Kimi-K2.5

# Per-role max output tokens for v1. Defaults are tuned for the v1 pipeline.
TOGETHER_DEFAULT_MAX_TOKENS=4096
TOGETHER_PROFILE_MAX_TOKENS=4096
TOGETHER_PLANNER_MAX_TOKENS=12000
TOGETHER_LAUNCH_PLANNER_MAX_TOKENS=6000
TOGETHER_WRITER_MAX_TOKENS=7000
TOGETHER_REVIEWER_MAX_TOKENS=4096
TOGETHER_CONTINUITY_MAX_TOKENS=12000
TOGETHER_SUMMARY_MAX_TOKENS=1024
TOGETHER_PUBLISHER_MAX_TOKENS=4096
TOGETHER_PERFECTIONIST_MAX_TOKENS=7000

# Embeddings + retrieval (used by both v1 retrieval.py and v2 episodic memory)
TOGETHER_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
RAG_TOP_K=5
RAG_RECENT_WINDOW=2

# v1 chapter discipline
MIN_CHAPTER_WORDS=2000
DEFAULT_INITIAL_CHAPTERS=3
